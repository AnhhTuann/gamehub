<Window x:Class="OmniWear.Warehouse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OmniWear Warehouse Manager" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#f3f4f6">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- Left Column: Products List -->
        <Border Grid.Column="0" Margin="10" Background="White" CornerRadius="8" Padding="10">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="1" Opacity="0.2"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Product Inventory" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Foreground="#1f2937"/>
                
                <DataGrid x:Name="ProductsGrid" Grid.Row="1" AutoGenerateColumns="False" 
                          IsReadOnly="True" SelectionChanged="ProductsGrid_SelectionChanged"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#e5e7eb" RowBackground="White"
                          AlternatingRowBackground="#f9fafb" BorderBrush="Transparent">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100" />
                        <DataGridTextColumn Header="Price ($)" Binding="{Binding Price}" Width="80" />
                        <DataGridTextColumn Header="Inventory" Binding="{Binding Inventory}" Width="80" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Right Column: Update Inventory -->
        <Border Grid.Column="1" Margin="0,10,10,10" Background="White" CornerRadius="8" Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="Gray" BlurRadius="10" ShadowDepth="1" Opacity="0.2"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Update Inventory" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1f2937"/>
                
                <TextBlock Text="Selected Product:" FontWeight="SemiBold" Foreground="#4b5563"/>
                <TextBlock x:Name="SelectedProductNameText" Text="None" Margin="0,5,0,15" TextWrapping="Wrap" Foreground="#1f2937"/>
                
                <TextBlock Text="New Inventory Count:" FontWeight="SemiBold" Foreground="#4b5563"/>
                <TextBox x:Name="InventoryTextBox" Margin="0,5,0,15" Padding="5" FontSize="14" BorderBrush="#d1d5db" BorderThickness="1"/>
                
                <Button x:Name="UpdateButton" Content="Update Inventory" Padding="10" FontSize="14" 
                        Background="#2563eb" Foreground="White" FontWeight="Bold" 
                        BorderThickness="0" Cursor="Hand" Click="UpdateButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
                
                <Button x:Name="RefreshButton" Content="Refresh Data" Padding="10" FontSize="14" 
                        Background="#10b981" Foreground="White" FontWeight="Bold" 
                        BorderThickness="0" Cursor="Hand" Margin="0,10,0,0" Click="RefreshButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock x:Name="StatusText" Text="" Margin="0,15,0,0" Foreground="Green" FontWeight="SemiBold" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
